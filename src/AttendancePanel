package smartuniversityportal;

import java.awt.*;
import java.awt.geom.RoundRectangle2D;
import java.sql.*;
import javax.swing.*;
import javax.swing.border.EmptyBorder;
import javax.swing.table.DefaultTableModel;

public class AttendancePanel extends JPanel {

    private final Color NAVY    = new Color(15,32,68);
    private final Color GREEN   = new Color(22,163,74);
    private final Color WHITE   = Color.WHITE;
    private final Color GRAY_BG = new Color(241,245,249);

    private JTable table;
    private DefaultTableModel model;
    private JComboBox<String> cmbCourse;
    private JTextField txtDate;
    private JButton btnLoad, btnSubmit;
    private JLabel lblStatus;

    // View table
    private JTable viewTable;
    private DefaultTableModel viewModel;
    private JComboBox<String> cmbViewCourse;
    private JButton btnView;
    private JLabel lblSummary;

    private JTabbedPane tabs;

    public AttendancePanel() {
        setLayout(new BorderLayout());
        setBackground(GRAY_BG);
        setBorder(new EmptyBorder(20,20,20,20));

        JLabel title = new JLabel("📋  Attendance Management");
        title.setFont(new Font("Georgia", Font.BOLD, 18));
        title.setForeground(NAVY);
        title.setBorder(new EmptyBorder(0,0,16,0));
        add(title, BorderLayout.NORTH);

        tabs = new JTabbedPane();
        tabs.setFont(new Font("SansSerif", Font.BOLD, 13));
        tabs.addTab("✏ Mark Attendance", makeMarkPanel());
        tabs.addTab("👁 View Attendance", makeViewPanel());
        add(tabs, BorderLayout.CENTER);
    }

    // ── MARK ATTENDANCE TAB ──
    private JPanel makeMarkPanel() {
        JPanel panel = new JPanel(new BorderLayout(0,12));
        panel.setBackground(GRAY_BG);
        panel.setBorder(new EmptyBorder(16,0,0,0));

        // Top controls
        JPanel controls = new JPanel(new FlowLayout(FlowLayout.LEFT,12,0));
        controls.setOpaque(false);

        cmbCourse = new JComboBox<>();
        cmbCourse.setFont(new Font("SansSerif", Font.PLAIN, 13));
        cmbCourse.setPreferredSize(new Dimension(220,36));
        loadCourseCombo(cmbCourse);

        txtDate = new JTextField(
            java.time.LocalDate.now().toString());
        txtDate.setFont(new Font("SansSerif", Font.PLAIN, 13));
        txtDate.setPreferredSize(new Dimension(130,36));
        txtDate.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(
                new Color(203,213,225),1,true),
            BorderFactory.createEmptyBorder(5,8,5,8)));

        btnLoad = makeBtn("📂 Load Students", new Color(26,86,219));
        btnLoad.addActionListener(e -> loadStudentsForAttendance());

        btnSubmit = makeBtn("✅ Submit Attendance", GREEN);
        btnSubmit.addActionListener(e -> submitAttendance());

        lblStatus = new JLabel("Select course and date, then load students.");
        lblStatus.setFont(new Font("SansSerif", Font.ITALIC, 12));
        lblStatus.setForeground(new Color(100,116,139));

        controls.add(new JLabel("Course:"));
        controls.add(cmbCourse);
        controls.add(new JLabel("Date (YYYY-MM-DD):"));
        controls.add(txtDate);
        controls.add(btnLoad);
        controls.add(btnSubmit);

        // Table
        String[] cols = {"Student ID","Roll No","Name","Status"};
        model = new DefaultTableModel(cols,0) {
            public boolean isCellEditable(int r, int c) {
                return c == 3;
            }
        };
        table = new JTable(model);
        table.setFont(new Font("SansSerif", Font.PLAIN, 13));
        table.setRowHeight(32);
        table.getTableHeader().setFont(
            new Font("SansSerif", Font.BOLD, 13));
        table.getTableHeader().setBackground(NAVY);
        table.getTableHeader().setForeground(WHITE);
        table.setGridColor(new Color(226,232,240));

        // Hide ID column
        table.getColumnModel().getColumn(0).setMinWidth(0);
        table.getColumnModel().getColumn(0).setMaxWidth(0);
        table.getColumnModel().getColumn(0).setWidth(0);

        // Present/Absent dropdown in Status column
        JComboBox<String> statusCombo =
            new JComboBox<>(new String[]{"Present","Absent"});
        table.getColumnModel().getColumn(3)
            .setCellEditor(new DefaultCellEditor(statusCombo));

        // Color rows by status
        table.setDefaultRenderer(Object.class,
            new javax.swing.table.DefaultTableCellRenderer() {
            @Override
            public Component getTableCellRendererComponent(
                JTable t, Object val, boolean sel,
                boolean focus, int row, int col) {
                super.getTableCellRendererComponent(
                    t,val,sel,focus,row,col);
                if (!sel) {
                    Object status = t.getValueAt(row,3);
                    if (status != null &&
                        status.toString().equals("Absent")) {
                        setBackground(new Color(255,220,220));
                    } else {
                        setBackground(new Color(220,255,220));
                    }
                }
                return this;
            }
        });

        JScrollPane scroll = new JScrollPane(table);
        scroll.setBorder(BorderFactory.createLineBorder(
            new Color(226,232,240),1,true));

        JPanel bottom = new JPanel(new FlowLayout(FlowLayout.LEFT));
        bottom.setOpaque(false);
        bottom.add(lblStatus);

        panel.add(controls, BorderLayout.NORTH);
        panel.add(scroll,   BorderLayout.CENTER);
        panel.add(bottom,   BorderLayout.SOUTH);
        return panel;
    }

    // ── VIEW ATTENDANCE TAB ──
    private JPanel makeViewPanel() {
        JPanel panel = new JPanel(new BorderLayout(0,12));
        panel.setBackground(GRAY_BG);
        panel.setBorder(new EmptyBorder(16,0,0,0));

        JPanel controls = new JPanel(new FlowLayout(FlowLayout.LEFT,12,0));
        controls.setOpaque(false);

        cmbViewCourse = new JComboBox<>();
        cmbViewCourse.setFont(new Font("SansSerif", Font.PLAIN, 13));
        cmbViewCourse.setPreferredSize(new Dimension(220,36));
        cmbViewCourse.addItem("-- All Courses --");
        loadCourseCombo(cmbViewCourse);

        btnView = makeBtn("🔍 Show Summary", new Color(26,86,219));
        btnView.addActionListener(e -> loadAttendanceSummary());

        lblSummary = new JLabel(" ");
        lblSummary.setFont(new Font("SansSerif", Font.BOLD, 13));
        lblSummary.setForeground(NAVY);

        controls.add(new JLabel("Filter by Course:"));
        controls.add(cmbViewCourse);
        controls.add(btnView);

        // View table
        String[] cols = {"Name","Roll No","Course",
                         "Total","Present","Absent","Attendance %"};
        viewModel = new DefaultTableModel(cols,0) {
            public boolean isCellEditable(int r, int c) {
                return false;
            }
        };
        viewTable = new JTable(viewModel);
        viewTable.setFont(new Font("SansSerif", Font.PLAIN, 13));
        viewTable.setRowHeight(32);
        viewTable.getTableHeader().setFont(
            new Font("SansSerif", Font.BOLD, 13));
        viewTable.getTableHeader().setBackground(NAVY);
        viewTable.getTableHeader().setForeground(WHITE);
        viewTable.setGridColor(new Color(226,232,240));

        // Color coding by attendance %
        viewTable.setDefaultRenderer(Object.class,
            new javax.swing.table.DefaultTableCellRenderer() {
            @Override
            public Component getTableCellRendererComponent(
                JTable t, Object val, boolean sel,
                boolean focus, int row, int col) {
                super.getTableCellRendererComponent(
                    t,val,sel,focus,row,col);
                if (!sel) {
                    Object pctObj = t.getValueAt(row,6);
                    if (pctObj != null) {
                        String pctStr = pctObj.toString()
                            .replace("%","").trim();
                        try {
                            double pct = Double.parseDouble(pctStr);
                            if (pct < 75)
                                setBackground(
                                    new Color(255,200,200));
                            else if (pct < 85)
                                setBackground(
                                    new Color(255,255,200));
                            else
                                setBackground(
                                    new Color(200,255,200));
                        } catch (Exception ex) {
                            setBackground(WHITE);
                        }
                    }
                }
                return this;
            }
        });

        JScrollPane scroll = new JScrollPane(viewTable);
        scroll.setBorder(BorderFactory.createLineBorder(
            new Color(226,232,240),1,true));

        JPanel bottom = new JPanel(new FlowLayout(FlowLayout.LEFT));
        bottom.setOpaque(false);
        bottom.add(lblSummary);

        panel.add(controls, BorderLayout.NORTH);
        panel.add(scroll,   BorderLayout.CENTER);
        panel.add(bottom,   BorderLayout.SOUTH);
        return panel;
    }

    // ── HELPERS ──
    private void loadCourseCombo(JComboBox<String> cmb) {
        try {
            Connection conn = DBConnection.getConnection();
            ResultSet rs = conn.createStatement().executeQuery(
                "SELECT course_id, course_name FROM courses " +
                "ORDER BY course_name");
            while (rs.next()) {
                cmb.addItem(rs.getInt("course_id") +
                    " - " + rs.getString("course_name"));
            }
            conn.close();
        } catch (Exception e) {
            System.out.println("Course load error: " + e.getMessage());
        }
    }

    private void loadStudentsForAttendance() {
        if (cmbCourse.getSelectedItem() == null) {
            JOptionPane.showMessageDialog(this,
                "Please select a course!");
            return;
        }
        try {
            Connection conn = DBConnection.getConnection();
            ResultSet rs = conn.createStatement().executeQuery(
                "SELECT student_id, roll_no, name FROM students " +
                "ORDER BY name");
            model.setRowCount(0);
            while (rs.next()) {
                model.addRow(new Object[]{
                    rs.getInt("student_id"),
                    rs.getString("roll_no"),
                    rs.getString("name"),
                    "Present"
                });
            }
            lblStatus.setText(model.getRowCount() +
                " students loaded. Change status if absent.");
            conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this,
                "Error: " + e.getMessage());
        }
    }

    private void submitAttendance() {
        if (model.getRowCount() == 0) {
            JOptionPane.showMessageDialog(this,
                "Please load students first!");
            return;
        }
        String date = txtDate.getText().trim();
        if (date.isEmpty()) {
            JOptionPane.showMessageDialog(this,
                "Please enter date! Format: YYYY-MM-DD");
            return;
        }
        String sel = cmbCourse.getSelectedItem().toString();
        int courseId = Integer.parseInt(sel.split(" - ")[0]);

        try {
            Connection conn = DBConnection.getConnection();

            // Duplicate check
            PreparedStatement chk = conn.prepareStatement(
                "SELECT COUNT(*) FROM attendance " +
                "WHERE course_id=? AND att_date=?");
            chk.setInt(1, courseId);
            chk.setString(2, date);
            ResultSet chkRs = chk.executeQuery();
            chkRs.next();
            if (chkRs.getInt(1) > 0) {
                JOptionPane.showMessageDialog(this,
                    "Attendance already marked for this " +
                    "date and course!");
                conn.close();
                return;
            }

            PreparedStatement ps = conn.prepareStatement(
                "INSERT INTO attendance" +
                "(student_id,course_id,att_date,status)" +
                " VALUES(?,?,?,?)");
            for (int i = 0; i < model.getRowCount(); i++) {
                ps.setInt(1,(int)model.getValueAt(i,0));
                ps.setInt(2, courseId);
                ps.setString(3, date);
                ps.setString(4, model.getValueAt(i,3).toString());
                ps.addBatch();
            }
            ps.executeBatch();
            JOptionPane.showMessageDialog(this,
                "✅ Attendance saved for " +
                model.getRowCount() + " students!");
            lblStatus.setText("Attendance saved for " + date);
            conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this,
                "Error: " + e.getMessage());
        }
    }

    private void loadAttendanceSummary() {
        try {
            Connection conn = DBConnection.getConnection();
            String query =
                "SELECT s.name, s.roll_no, c.course_name, " +
                "COUNT(*) as total, " +
                "SUM(CASE WHEN a.status='Present' THEN 1 ELSE 0 END)" +
                " as present_count, " +
                "SUM(CASE WHEN a.status='Absent' THEN 1 ELSE 0 END)" +
                " as absent_count, " +
                "ROUND(SUM(CASE WHEN a.status='Present' " +
                "THEN 1 ELSE 0 END)*100.0/COUNT(*),1) as pct " +
                "FROM attendance a " +
                "JOIN students s ON a.student_id=s.student_id " +
                "JOIN courses c ON a.course_id=c.course_id ";

            if (cmbViewCourse.getSelectedIndex() > 0) {
                String s = cmbViewCourse.getSelectedItem().toString();
                int cid = Integer.parseInt(s.split(" - ")[0]);
                query += "WHERE a.course_id=" + cid + " ";
            }
            query += "GROUP BY s.student_id, c.course_id " +
                     "ORDER BY s.name";

            ResultSet rs = conn.createStatement().executeQuery(query);
            viewModel.setRowCount(0);
            int below75 = 0;
            while (rs.next()) {
                double pct = rs.getDouble("pct");
                if (pct < 75) below75++;
                viewModel.addRow(new Object[]{
                    rs.getString("name"),
                    rs.getString("roll_no"),
                    rs.getString("course_name"),
                    rs.getInt("total"),
                    rs.getInt("present_count"),
                    rs.getInt("absent_count"),
                    pct + "%"
                });
            }
            lblSummary.setText(viewModel.getRowCount() +
                " records | ⚠ " + below75 +
                " students below 75% attendance");
            conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this,
                "Error: " + e.getMessage());
        }
    }

    private JButton makeBtn(String text, Color color) {
        JButton btn = new JButton(text) {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover() ?
                    color.darker() : color);
                g2.fill(new RoundRectangle2D.Double(
                    0,0,getWidth(),getHeight(),8,8));
                super.paintComponent(g);
            }
        };
        btn.setFont(new Font("SansSerif", Font.BOLD, 12));
        btn.setForeground(WHITE);
        btn.setOpaque(false);
        btn.setContentAreaFilled(false);
        btn.setBorderPainted(false);
        btn.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        return btn;
    }
}
