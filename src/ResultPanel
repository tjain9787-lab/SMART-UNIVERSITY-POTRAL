package smartuniversityportal;

import java.awt.*;
import java.awt.geom.RoundRectangle2D;
import java.sql.*;
import javax.swing.*;
import javax.swing.border.EmptyBorder;
import javax.swing.table.DefaultTableModel;

public class ResultPanel extends JPanel {

    private final Color NAVY    = new Color(15,32,68);
    private final Color BLUE    = new Color(26,86,219);
    private final Color WHITE   = Color.WHITE;
    private final Color GRAY_BG = new Color(241,245,249);

    private JTable table;
    private DefaultTableModel model;
    private JComboBox<String> cmbStudent, cmbCourse,
                               cmbGrade, cmbExamType;
    private JTextField txtMarks, txtTotal;
    private JButton btnAdd, btnDelete, btnClear;

    public ResultPanel() {
        setLayout(new BorderLayout());
        setBackground(GRAY_BG);
        setBorder(new EmptyBorder(20,20,20,20));
        add(makeTopBar(),    BorderLayout.NORTH);
        add(makeCenter(),    BorderLayout.CENTER);
        add(makeFormPanel(), BorderLayout.EAST);
        loadResults();
    }

    private JPanel makeTopBar() {
        JPanel bar = new JPanel(new BorderLayout());
        bar.setOpaque(false);
        bar.setBorder(new EmptyBorder(0,0,16,0));
        JLabel title = new JLabel("📊  Result Management");
        title.setFont(new Font("Georgia", Font.BOLD, 18));
        title.setForeground(NAVY);
        bar.add(title, BorderLayout.WEST);
        return bar;
    }

    private JScrollPane makeCenter() {
        String[] cols = {"ID","Student","Roll No",
                         "Course","Marks","Total","Grade","Exam"};
        model = new DefaultTableModel(cols,0) {
            public boolean isCellEditable(int r, int c) {
                return false;
            }
        };
        table = new JTable(model);
        table.setFont(new Font("SansSerif", Font.PLAIN, 13));
        table.setRowHeight(32);
        table.getTableHeader().setFont(
            new Font("SansSerif", Font.BOLD, 13));
        table.getTableHeader().setBackground(NAVY);
        table.getTableHeader().setForeground(WHITE);
        table.setGridColor(new Color(226,232,240));
        table.setSelectionBackground(new Color(219,234,254));

        // Hide ID
        table.getColumnModel().getColumn(0).setMinWidth(0);
        table.getColumnModel().getColumn(0).setMaxWidth(0);
        table.getColumnModel().getColumn(0).setWidth(0);

        // Color rows by grade
        table.setDefaultRenderer(Object.class,
            new javax.swing.table.DefaultTableCellRenderer() {
            @Override
            public Component getTableCellRendererComponent(
                JTable t, Object val, boolean sel,
                boolean focus, int row, int col) {
                super.getTableCellRendererComponent(
                    t,val,sel,focus,row,col);
                if (!sel) {
                    Object g = t.getValueAt(row,6);
                    if (g != null) {
                        switch(g.toString()) {
                        case "A+": case "A":
                            setBackground(new Color(200,255,200));
                            break;
                        case "B+": case "B":
                            setBackground(new Color(220,240,255));
                            break;
                        case "F":
                            setBackground(new Color(255,200,200));
                            break;
                        default:
                            setBackground(new Color(255,255,220));
                        }
                    }
                }
                return this;
            }
        });

        // Row click → fill form
        table.addMouseListener(new java.awt.event.MouseAdapter() {
            public void mouseClicked(java.awt.event.MouseEvent e) {
                int row = table.getSelectedRow();
                if (row != -1) {
                    txtMarks.setText(
                        model.getValueAt(row,4).toString());
                    txtTotal.setText(
                        model.getValueAt(row,5).toString());
                    cmbGrade.setSelectedItem(
                        model.getValueAt(row,6).toString());
                    cmbExamType.setSelectedItem(
                        model.getValueAt(row,7).toString());
                }
            }
        });

        JScrollPane scroll = new JScrollPane(table);
        scroll.setBorder(BorderFactory.createLineBorder(
            new Color(226,232,240),1,true));
        return scroll;
    }

    private JPanel makeFormPanel() {
        JPanel form = new JPanel() {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fill(new RoundRectangle2D.Double(
                    0,0,getWidth(),getHeight(),16,16));
            }
        };
        form.setOpaque(false);
        form.setLayout(new BoxLayout(form, BoxLayout.Y_AXIS));
        form.setBorder(new EmptyBorder(20,20,20,20));
        form.setPreferredSize(new Dimension(250,0));

        JLabel t = new JLabel("Enter Result");
        t.setFont(new Font("Georgia", Font.BOLD, 15));
        t.setForeground(NAVY);
        t.setAlignmentX(Component.LEFT_ALIGNMENT);

        cmbStudent  = makeCombo();
        cmbCourse   = makeCombo();
        cmbGrade    = makeCombo();
        cmbExamType = makeCombo();
        txtMarks = makeField();
        txtTotal = makeField();
        txtTotal.setText("100");

        // Load dropdowns
        loadStudentCombo();
        loadCourseCombo();
        for (String g : new String[]{
                "A+","A","B+","B","C+","C","D","F"})
            cmbGrade.addItem(g);
        for (String ex : new String[]{
                "Mid-Term","Final","Assignment","Practical"})
            cmbExamType.addItem(ex);

        // Auto grade on marks entry
        txtMarks.addFocusListener(new java.awt.event.FocusAdapter() {
            public void focusLost(java.awt.event.FocusEvent e) {
                autoGrade();
            }
        });

        btnAdd    = makeBtn("➕ Add Result", BLUE);
        btnDelete = makeBtn("🗑 Delete",
            new Color(220,38,38));
        btnClear  = makeBtn("✕ Clear",
            new Color(100,116,139));

        for (JButton b : new JButton[]{btnAdd,btnDelete,btnClear})
            b.setMaximumSize(new Dimension(Integer.MAX_VALUE,38));

        btnAdd.addActionListener(e    -> addResult());
        btnDelete.addActionListener(e -> deleteResult());
        btnClear.addActionListener(e  -> clearForm());

        form.add(t);
        form.add(Box.createVerticalStrut(12));
        form.add(lbl("Student"));   form.add(cmbStudent);
        form.add(Box.createVerticalStrut(8));
        form.add(lbl("Course"));    form.add(cmbCourse);
        form.add(Box.createVerticalStrut(8));
        form.add(lbl("Marks"));     form.add(txtMarks);
        form.add(Box.createVerticalStrut(8));
        form.add(lbl("Total Marks"));form.add(txtTotal);
        form.add(Box.createVerticalStrut(8));
        form.add(lbl("Grade (auto)"));form.add(cmbGrade);
        form.add(Box.createVerticalStrut(8));
        form.add(lbl("Exam Type")); form.add(cmbExamType);
        form.add(Box.createVerticalStrut(16));
        form.add(btnAdd);
        form.add(Box.createVerticalStrut(6));
        form.add(btnDelete);
        form.add(Box.createVerticalStrut(6));
        form.add(btnClear);
        return form;
    }

    // ── HELPERS ──
    private JLabel lbl(String t) {
        JLabel l = new JLabel(t);
        l.setFont(new Font("SansSerif", Font.BOLD, 11));
        l.setForeground(new Color(51,65,85));
        l.setAlignmentX(Component.LEFT_ALIGNMENT);
        return l;
    }

    private JTextField makeField() {
        JTextField tf = new JTextField();
        tf.setFont(new Font("SansSerif", Font.PLAIN, 12));
        tf.setMaximumSize(new Dimension(Integer.MAX_VALUE,34));
        tf.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(
                new Color(203,213,225),1,true),
            BorderFactory.createEmptyBorder(5,8,5,8)));
        tf.setAlignmentX(Component.LEFT_ALIGNMENT);
        return tf;
    }

    private JComboBox<String> makeCombo() {
        JComboBox<String> cb = new JComboBox<>();
        cb.setFont(new Font("SansSerif", Font.PLAIN, 12));
        cb.setMaximumSize(new Dimension(Integer.MAX_VALUE,34));
        cb.setAlignmentX(Component.LEFT_ALIGNMENT);
        return cb;
    }

    private JButton makeBtn(String text, Color color) {
        JButton btn = new JButton(text) {
            @Override
            protected void paintComponent(Graphics g) {
                Graphics2D g2 = (Graphics2D) g;
                g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover() ?
                    color.darker() : color);
                g2.fill(new RoundRectangle2D.Double(
                    0,0,getWidth(),getHeight(),8,8));
                super.paintComponent(g);
            }
        };
        btn.setFont(new Font("SansSerif", Font.BOLD, 12));
        btn.setForeground(WHITE);
        btn.setOpaque(false);
        btn.setContentAreaFilled(false);
        btn.setBorderPainted(false);
        btn.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        btn.setAlignmentX(Component.LEFT_ALIGNMENT);
        return btn;
    }

    private void loadStudentCombo() {
        try {
            Connection conn = DBConnection.getConnection();
            ResultSet rs = conn.createStatement().executeQuery(
                "SELECT student_id,name,roll_no FROM students " +
                "ORDER BY name");
            cmbStudent.removeAllItems();
            while (rs.next())
                cmbStudent.addItem(rs.getInt("student_id") +
                    " - " + rs.getString("name") +
                    " (" + rs.getString("roll_no") + ")");
            conn.close();
        } catch (Exception e) {
            System.out.println("Error: " + e.getMessage());
        }
    }

    private void loadCourseCombo() {
        try {
            Connection conn = DBConnection.getConnection();
            ResultSet rs = conn.createStatement().executeQuery(
                "SELECT course_id,course_name FROM courses " +
                "ORDER BY course_name");
            cmbCourse.removeAllItems();
            while (rs.next())
                cmbCourse.addItem(rs.getInt("course_id") +
                    " - " + rs.getString("course_name"));
            conn.close();
        } catch (Exception e) {
            System.out.println("Error: " + e.getMessage());
        }
    }

    private void autoGrade() {
        try {
            int marks = Integer.parseInt(txtMarks.getText().trim());
            String grade;
            if      (marks >= 90) grade = "A+";
            else if (marks >= 80) grade = "A";
            else if (marks >= 70) grade = "B+";
            else if (marks >= 60) grade = "B";
            else if (marks >= 50) grade = "C+";
            else if (marks >= 40) grade = "C";
            else if (marks >= 33) grade = "D";
            else                  grade = "F";
            cmbGrade.setSelectedItem(grade);
        } catch (NumberFormatException ex) { }
    }

    private void loadResults() {
        try {
            Connection conn = DBConnection.getConnection();
            ResultSet rs = conn.createStatement().executeQuery(
                "SELECT r.result_id, s.name, s.roll_no, " +
                "c.course_name, r.marks, r.total_marks, " +
                "r.grade, r.exam_type " +
                "FROM results r " +
                "JOIN students s ON r.student_id=s.student_id " +
                "JOIN courses c ON r.course_id=c.course_id " +
                "ORDER BY s.name");
            model.setRowCount(0);
            while (rs.next()) {
                model.addRow(new Object[]{
                    rs.getInt(1), rs.getString(2),
                    rs.getString(3), rs.getString(4),
                    rs.getInt(5),   rs.getInt(6),
                    rs.getString(7),rs.getString(8)
                });
            }
            conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this,
                "Error: " + e.getMessage());
        }
    }

    private void addResult() {
        if (txtMarks.getText().trim().isEmpty()) {
            JOptionPane.showMessageDialog(this,
                "Please enter marks!");
            return;
        }
        try {
            int sid = Integer.parseInt(
                cmbStudent.getSelectedItem()
                    .toString().split(" - ")[0]);
            int cid = Integer.parseInt(
                cmbCourse.getSelectedItem()
                    .toString().split(" - ")[0]);
            int marks = Integer.parseInt(txtMarks.getText().trim());
            int total = Integer.parseInt(txtTotal.getText().trim());
            String grade = cmbGrade.getSelectedItem().toString();
            String exam  = cmbExamType.getSelectedItem().toString();

            Connection conn = DBConnection.getConnection();

            // Duplicate check
            PreparedStatement chk = conn.prepareStatement(
                "SELECT COUNT(*) FROM results WHERE " +
                "student_id=? AND course_id=? AND exam_type=?");
            chk.setInt(1,sid); chk.setInt(2,cid);
            chk.setString(3,exam);
            ResultSet chkRs = chk.executeQuery();
            chkRs.next();
            if (chkRs.getInt(1) > 0) {
                JOptionPane.showMessageDialog(this,
                    "Result already exists for this " +
                    "student + course + exam type!");
                conn.close();
                return;
            }

            PreparedStatement ps = conn.prepareStatement(
                "INSERT INTO results(student_id,course_id," +
                "marks,total_marks,grade,exam_type) " +
                "VALUES(?,?,?,?,?,?)");
            ps.setInt(1,sid); ps.setInt(2,cid);
            ps.setInt(3,marks); ps.setInt(4,total);
            ps.setString(5,grade); ps.setString(6,exam);
            ps.executeUpdate();
            JOptionPane.showMessageDialog(this,
                "✅ Result added!");
            loadResults(); clearForm(); conn.close();
        } catch (Exception e) {
            JOptionPane.showMessageDialog(this,
                "Error: " + e.getMessage());
        }
    }

    private void deleteResult() {
        int row = table.getSelectedRow();
        if (row == -1) {
            JOptionPane.showMessageDialog(this,
                "Select a result to delete!");
            return;
        }
        int c = JOptionPane.showConfirmDialog(this,
            "Delete this result?","Confirm",
            JOptionPane.YES_NO_OPTION);
        if (c == JOptionPane.YES_OPTION) {
            try {
                int id = (int) model.getValueAt(row,0);
                Connection conn = DBConnection.getConnection();
                PreparedStatement ps = conn.prepareStatement(
                    "DELETE FROM results WHERE result_id=?");
                ps.setInt(1,id);
                ps.executeUpdate();
                JOptionPane.showMessageDialog(this,
                    "✅ Result deleted!");
                loadResults(); conn.close();
            } catch (Exception e) {
                JOptionPane.showMessageDialog(this,
                    "Error: " + e.getMessage());
            }
        }
    }

    private void clearForm() {
        txtMarks.setText("");
        txtTotal.setText("100");
        cmbGrade.setSelectedIndex(0);
        cmbExamType.setSelectedIndex(0);
        table.clearSelection();
    }
}
