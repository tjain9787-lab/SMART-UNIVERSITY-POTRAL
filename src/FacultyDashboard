package smartuniversityportal;

import java.awt.*;
import java.awt.geom.RoundRectangle2D;
import java.sql.*;
import javax.swing.*;
import javax.swing.border.EmptyBorder;

public class FacultyDashboard extends JFrame {

    private final Color NAVY    = new Color(15,32,68);
    private final Color GREEN   = new Color(22,163,74);
    private final Color WHITE   = Color.WHITE;
    private final Color GRAY_BG = new Color(241,245,249);
    private final Color GRAY_TXT= new Color(100,116,139);

    private String facultyName;
    private JPanel mainPanel;
    private JLabel lblCourses, lblStudents, lblToday;

    public FacultyDashboard(String facultyName) {
        this.facultyName = facultyName;
        initUI();
        loadStats();
    }

    public FacultyDashboard() { this("Faculty"); }

    private void initUI() {
        setTitle("Smart University Portal — Faculty Dashboard");
        setSize(1000,650);
        setLocationRelativeTo(null);
        setDefaultCloseOperation(EXIT_ON_CLOSE);
        setLayout(new BorderLayout());
        getContentPane().setBackground(GRAY_BG);
        add(makeSidebar(), BorderLayout.WEST);
        add(makeHeader(),  BorderLayout.NORTH);
        add(makeContent(), BorderLayout.CENTER);
    }

    private JPanel makeSidebar() {
        JPanel sb = new JPanel(){
            @Override
            protected void paintComponent(Graphics g){
                super.paintComponent(g);
                Graphics2D g2=(Graphics2D)g;
                GradientPaint gp=new GradientPaint(
                    0,0,NAVY,0,getHeight(),
                    new Color(10,20,50));
                g2.setPaint(gp);
                g2.fillRect(0,0,getWidth(),getHeight());
            }
        };
        sb.setPreferredSize(new Dimension(200,0));
        sb.setLayout(new BoxLayout(sb,BoxLayout.Y_AXIS));
        sb.setBorder(new EmptyBorder(20,0,20,0));

        JLabel icon = new JLabel("👨‍🏫",SwingConstants.CENTER);
        icon.setFont(new Font("Segoe UI Emoji",Font.PLAIN,30));
        icon.setAlignmentX(Component.CENTER_ALIGNMENT);

        JLabel name = new JLabel(facultyName);
        name.setFont(new Font("Georgia",Font.BOLD,13));
        name.setForeground(WHITE);
        name.setAlignmentX(Component.CENTER_ALIGNMENT);

        JLabel role = new JLabel("Faculty");
        role.setFont(new Font("SansSerif",Font.PLAIN,11));
        role.setForeground(new Color(147,197,253));
        role.setAlignmentX(Component.CENTER_ALIGNMENT);

        sb.add(icon);
        sb.add(Box.createVerticalStrut(8));
        sb.add(name); sb.add(role);
        sb.add(Box.createVerticalStrut(20));

        JSeparator sep = new JSeparator();
        sep.setForeground(new Color(255,255,255,40));
        sep.setMaximumSize(new Dimension(160,1));
        sep.setAlignmentX(Component.CENTER_ALIGNMENT);
        sb.add(sep);
        sb.add(Box.createVerticalStrut(16));

        String[][] items = {
            {"🏠","Dashboard"},
            {"📋","Mark Attendance"},
            {"📊","Enter Results"},
            {"👥","View Students"},
        };

        for(String[] item : items){
            sb.add(makeSideBtn(item[0],item[1]));
            sb.add(Box.createVerticalStrut(4));
        }

        sb.add(Box.createVerticalGlue());
        JButton out = makeSideBtn("🚪","Logout");
        out.addActionListener(e->{
            new Login().setVisible(true);
            dispose();
        });
        sb.add(out);
        return sb;
    }

    private JButton makeSideBtn(String icon, String lbl) {
        JButton btn = new JButton(icon+"  "+lbl){
            @Override
            protected void paintComponent(Graphics g){
                Graphics2D g2=(Graphics2D)g;
                g2.setRenderingHint(
                    RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);
                if(getModel().isRollover()){
                    g2.setColor(new Color(26,86,219,80));
                    g2.fill(new RoundRectangle2D.Double(
                        8,2,getWidth()-16,getHeight()-4,8,8));
                }
                super.paintComponent(g);
            }
        };
        btn.setFont(new Font("Segoe UI Emoji",Font.PLAIN,12));
        btn.setForeground(new Color(200,220,255));
        btn.setOpaque(false);
        btn.setContentAreaFilled(false);
        btn.setBorderPainted(false);
        btn.setHorizontalAlignment(SwingConstants.LEFT);
        btn.setMaximumSize(new Dimension(180,38));
        btn.setAlignmentX(Component.CENTER_ALIGNMENT);
        btn.setCursor(Cursor.getPredefinedCursor(
            Cursor.HAND_CURSOR));
        btn.setBorder(new EmptyBorder(0,20,0,0));
        btn.addActionListener(e->loadModule(lbl));
        return btn;
    }

    private JPanel makeHeader() {
        JPanel h = new JPanel(new BorderLayout());
        h.setBackground(WHITE);
        h.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createMatteBorder(
                0,0,1,0,new Color(226,232,240)),
            new EmptyBorder(14,24,14,24)));
        JLabel t = new JLabel("Faculty Dashboard");
        t.setFont(new Font("Georgia",Font.BOLD,18));
        t.setForeground(NAVY);
        JLabel info = new JLabel(
            "👨‍🏫 "+facultyName+" | "+
            java.time.LocalDate.now());
        info.setFont(new Font("SansSerif",Font.PLAIN,12));
        info.setForeground(GRAY_TXT);
        h.add(t,   BorderLayout.WEST);
        h.add(info,BorderLayout.EAST);
        return h;
    }

    private JScrollPane makeContent() {
        mainPanel = new JPanel(new BorderLayout());
        mainPanel.setBackground(GRAY_BG);
        mainPanel.setBorder(new EmptyBorder(24,24,24,24));
        showHome();
        JScrollPane sc = new JScrollPane(mainPanel);
        sc.setBorder(null);
        return sc;
    }

    private void showHome() {
        mainPanel.removeAll();
        JPanel home = new JPanel();
        home.setOpaque(false);
        home.setLayout(new BoxLayout(home,BoxLayout.Y_AXIS));

        JLabel greet = new JLabel(
            "Good Day, "+facultyName+"! 👋");
        greet.setFont(new Font("Georgia",Font.BOLD,22));
        greet.setForeground(NAVY);
        greet.setAlignmentX(Component.LEFT_ALIGNMENT);

        home.add(greet);
        home.add(Box.createVerticalStrut(24));

        // Stat cards
        JPanel cards = new JPanel(new GridLayout(1,3,16,0));
        cards.setOpaque(false);
        cards.setMaximumSize(new Dimension(Integer.MAX_VALUE,110));
        cards.setAlignmentX(Component.LEFT_ALIGNMENT);

        lblCourses  = new JLabel("...");
        lblStudents = new JLabel("...");
        lblToday    = new JLabel(
            java.time.LocalDate.now().toString());

        cards.add(makeCard("📚 My Courses",
            lblCourses,
            new Color(254,249,195),
            new Color(161,98,7)));
        cards.add(makeCard("👥 Total Students",
            lblStudents,
            new Color(219,234,254),
            new Color(26,86,219)));
        cards.add(makeCard("📅 Today",
            lblToday,
            new Color(220,252,231),GREEN));

        home.add(cards);
        home.add(Box.createVerticalStrut(28));

        // Quick actions
        JLabel qa = new JLabel("Quick Actions");
        qa.setFont(new Font("Georgia",Font.BOLD,16));
        qa.setForeground(NAVY);
        qa.setAlignmentX(Component.LEFT_ALIGNMENT);
        home.add(qa);
        home.add(Box.createVerticalStrut(12));

        JPanel qrow = new JPanel(new GridLayout(1,2,16,0));
        qrow.setOpaque(false);
        qrow.setMaximumSize(new Dimension(Integer.MAX_VALUE,55));
        qrow.setAlignmentX(Component.LEFT_ALIGNMENT);

        qrow.add(makeQBtn("📋 Mark Today's Attendance",GREEN));
        qrow.add(makeQBtn("📊 Enter Results",
            new Color(26,86,219)));
        home.add(qrow);

        mainPanel.add(home,BorderLayout.NORTH);
        mainPanel.revalidate();
        mainPanel.repaint();
    }

    private void loadStats() {
        try {
            Connection conn = DBConnection.getConnection();
            ResultSet r1 = conn.createStatement().executeQuery(
                "SELECT COUNT(*) FROM courses");
            r1.next();
            lblCourses.setText(String.valueOf(r1.getInt(1)));

            ResultSet r2 = conn.createStatement().executeQuery(
                "SELECT COUNT(*) FROM students");
            r2.next();
            lblStudents.setText(String.valueOf(r2.getInt(1)));
            conn.close();
        } catch(Exception e){
            System.out.println("Stats: "+e.getMessage());
        }
    }

    private void loadModule(String mod) {
        mainPanel.removeAll();
        switch(mod){
            case "Dashboard":
                showHome(); return;
            case "Mark Attendance":
                mainPanel.add(new AttendancePanel(),
                    BorderLayout.CENTER);
                break;
            case "Enter Results":
                mainPanel.add(new ResultPanel(),
                    BorderLayout.CENTER);
                break;
            case "View Students":
                mainPanel.add(new StudentPanel(),
                    BorderLayout.CENTER);
                break;
            default:
                JLabel s = new JLabel(mod+" — Coming Soon!",
                    SwingConstants.CENTER);
                s.setFont(new Font("Georgia",Font.BOLD,18));
                s.setForeground(GRAY_TXT);
                mainPanel.add(s,BorderLayout.CENTER);
        }
        mainPanel.revalidate();
        mainPanel.repaint();
    }

    private JPanel makeCard(String title,JLabel num,
                             Color bg,Color accent){
        JPanel c=new JPanel(){
            @Override
            protected void paintComponent(Graphics g){
                Graphics2D g2=(Graphics2D)g;
                g2.setRenderingHint(
                    RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(WHITE);
                g2.fill(new RoundRectangle2D.Double(
                    0,0,getWidth(),getHeight(),14,14));
                g2.setColor(bg);
                g2.fill(new RoundRectangle2D.Double(
                    0,0,getWidth(),40,14,14));
                g2.fillRect(0,26,getWidth(),14);
            }
        };
        c.setOpaque(false);
        c.setLayout(new BorderLayout());
        c.setBorder(new EmptyBorder(14,16,14,16));
        JLabel tl=new JLabel(title);
        tl.setFont(new Font("SansSerif",Font.BOLD,12));
        tl.setForeground(accent);
        num.setFont(new Font("Georgia",Font.BOLD,22));
        num.setForeground(NAVY);
        c.add(tl, BorderLayout.NORTH);
        c.add(num,BorderLayout.CENTER);
        return c;
    }

    private JButton makeQBtn(String text,Color color){
        JButton b=new JButton(text){
            @Override
            protected void paintComponent(Graphics g){
                Graphics2D g2=(Graphics2D)g;
                g2.setRenderingHint(
                    RenderingHints.KEY_ANTIALIASING,
                    RenderingHints.VALUE_ANTIALIAS_ON);
                g2.setColor(getModel().isRollover()?
                    color.darker():color);
                g2.fill(new RoundRectangle2D.Double(
                    0,0,getWidth(),getHeight(),10,10));
                super.paintComponent(g);
            }
        };
        b.setFont(new Font("SansSerif",Font.BOLD,12));
        b.setForeground(WHITE);
        b.setOpaque(false);
        b.setContentAreaFilled(false);
        b.setBorderPainted(false);
        b.setCursor(Cursor.getPredefinedCursor(
            Cursor.HAND_CURSOR));
        b.addActionListener(e->loadModule(
            text.contains("Attendance")?
                "Mark Attendance":"Enter Results"));
        return b;
    }
}
