    // ── Helper: make label ──
    private JLabel makeLabel(String text) {
        JLabel lbl = new JLabel(text);
        lbl.setFont(new Font("SansSerif", Font.BOLD, 12));
        lbl.setForeground(new Color(51, 65, 85));
        lbl.setAlignmentX(Component.LEFT_ALIGNMENT);
        return lbl;
    }

    // ── Helper: make text field ──
    private JTextField makeTextField(String placeholder) {
        JTextField tf = new JTextField();
        styleField(tf, placeholder);
        return tf;
    }

    // ── Helper: style any text component ──
    private void styleField(JTextField tf, String placeholder) {
        tf.setFont(new Font("SansSerif", Font.PLAIN, 13));
        tf.setForeground(new Color(51, 65, 85));
        tf.setBackground(new Color(248, 250, 252));
        tf.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(203, 213, 225), 1, true),
            BorderFactory.createEmptyBorder(8, 12, 8, 12)));
        tf.setMaximumSize(new Dimension(Integer.MAX_VALUE, 40));

        // Placeholder effect
        tf.setText(placeholder);
        tf.setForeground(new Color(148, 163, 184));
        tf.addFocusListener(new FocusAdapter() {
            @Override
            public void focusGained(FocusEvent e) {
                if (tf.getText().equals(placeholder)) {
                    tf.setText("");
                    tf.setForeground(new Color(51, 65, 85));
                }
                tf.setBorder(BorderFactory.createCompoundBorder(
                    BorderFactory.createLineBorder(BLUE, 1, true),
                    BorderFactory.createEmptyBorder(8, 12, 8, 12)));
            }
            @Override
            public void focusLost(FocusEvent e) {
                if (tf.getText().isEmpty()) {
                    tf.setText(placeholder);
                    tf.setForeground(new Color(148, 163, 184));
                }
                tf.setBorder(BorderFactory.createCompoundBorder(
                    BorderFactory.createLineBorder(new Color(203, 213, 225), 1, true),
                    BorderFactory.createEmptyBorder(8, 12, 8, 12)));
            }
        });
    }

    // ── Login Logic ──
    private void doLogin() {
        String username = txtUsername.getText().trim();
        String password = new String(txtPassword.getPassword()).trim();
        String role = cmbRole.getSelectedItem().toString();

        // Validation
        if (username.isEmpty() || username.equals("Enter username")) {
            lblError.setText("⚠ Please enter your username!");
            txtUsername.requestFocus();
            return;
        }
        if (password.isEmpty() || password.equals("Enter password")) {
            lblError.setText("⚠ Please enter your password!");
            txtPassword.requestFocus();
            return;
        }
        if (role.equals("-- Select Role --")) {
            lblError.setText("⚠ Please select your role!");
            return;
        }

        // DB Check
        try {
            Connection conn = DBConnection.getConnection();
            String query =
                "SELECT * FROM users WHERE username=? " +
                "AND password=? AND role=?";
            PreparedStatement ps = conn.prepareStatement(query);
            ps.setString(1, username);
            ps.setString(2, password);
            ps.setString(3, role.toLowerCase());
            ResultSet rs = ps.executeQuery();

            if (rs.next()) {
                lblError.setText(" ");
                JOptionPane.showMessageDialog(this,
                    "✅ Welcome " + username + "!",
                    "Login Successful",
                    JOptionPane.INFORMATION_MESSAGE);

                // Role ke hisaab se dashboard open karo
                switch (role) {
                    case "Admin":
                        new AdminDashboard().setVisible(true);
                        break;
                    case "Faculty":
                        new FacultyDashboard(username).setVisible(true);
                        break;
                    case "Student":
                        ResultSet stuRs = conn.prepareStatement(
                                "SELECT s.student_id FROM students s " +
                                "JOIN users u ON s.roll_no = u.username " +
                                "WHERE u.username='" + username + "'")
                                .executeQuery();
                        int stuId = stuRs.next() ? stuRs.getInt(1) : 1;
                        new StudentDashboard(stuId, username)
                                .setVisible(true);
                        break;
                }
                this.dispose();

            } else {
                lblError.setText("⚠ Invalid username, password or role!");
                txtPassword.setText("");
                txtPassword.requestFocus();
            }

            rs.close(); ps.close(); conn.close();

        } catch (Exception ex) {
            lblError.setText("⚠ DB Error: " + ex.getMessage());
        }
    }

