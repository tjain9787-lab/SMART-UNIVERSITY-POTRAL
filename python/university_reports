    "import matplotlib.pyplot as plt\n",
    "import pandas as pd\n",
    "\n",
    "# Data\n",
    "students_data = {\n",
    "    'Student': ['Tanisha Arora', 'Rohan Mehta', 'Priya Singh'],\n",
    "    'Attendance%': [84, 60, 100]\n",
    "}\n",
    "\n",
    "df = pd.DataFrame(students_data)\n",
    "\n",
    "# Colors\n",
    "colors = ['#16a34a' if x >= 85 else '#fbbf24' if x >= 75 else '#ef4444' \n",
    "          for x in df['Attendance%']]\n",
    "\n",
    "plt.figure(figsize=(10, 6))\n",
    "bars = plt.barh(df['Student'], df['Attendance%'], color=colors, edgecolor='black', linewidth=1.5)\n",
    "plt.xlabel('Attendance %', fontsize=12, fontweight='bold')\n",
    "plt.title('Student Attendance Tracking Report', fontsize=14, fontweight='bold')\n",
    "plt.xlim(0, 100)\n",
    "plt.axvline(x=75, color='red', linestyle='--', linewidth=2, label='75% Threshold')\n",
    "\n",
    "for i, bar in enumerate(bars):\n",
    "    plt.text(bar.get_width() + 1, bar.get_y() + bar.get_height()/2, \n",
    "             f\"{df['Attendance%'].iloc[i]}%\", va='center', fontweight='bold')\n",
    "\n",
    "plt.legend()\n",
    "plt.tight_layout()\n",
    "plt.savefig('attendance_report.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "print(\"✅ Attendance chart saved!\")"
   ]
